<?xml version="1.0" encoding="utf-8"?>
<!-- Fond sombre radial de l'écran d'accueil (esprit du lobby) : halo haut -> nuit. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="640dp"
        android:centerX="0.5"
        android:centerY="0.30"
        android:startColor="@color/panneau_haut"
        android:endColor="@color/nuit" />
</shape>
