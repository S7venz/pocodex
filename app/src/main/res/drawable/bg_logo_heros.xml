<?xml version="1.0" encoding="utf-8"?>
<!-- Plaque logo : carré arrondi rouge en relief (face + ombre dure), façon btn_red. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/rouge_ombre" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/rouge_clair"
                android:endColor="@color/rouge" />
            <corners android:radius="24dp" />
            <stroke android:width="2dp" android:color="#59FFFFFF" />
        </shape>
    </item>
</layer-list>
