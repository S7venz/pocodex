<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:strokeColor="#8CFFFFFF"
    app:strokeWidth="2dp">

    <FrameLayout
        android:id="@+id/carteFond"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="11dp">

        <ImageView
            android:id="@+id/imgPokeball"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-18dp"
            android:layout_marginEnd="-22dp"
            android:alpha="0.16"
            android:contentDescription="@null"
            android:src="@drawable/ic_pokeball"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNumero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/press_start_2p"
                android:includeFontPadding="false"
                android:textColor="#EAFFFFFF"
                android:textSize="8sp" />

            <ImageView
                android:id="@+id/imgPokemon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/txtNom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/baloo2_black"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:shadowColor="#52000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3"
                android:textColor="#FFFFFF"
                android:textSize="17sp" />

            <LinearLayout
                android:id="@+id/chipsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/foil_sheen" />

        <!-- Badge « capturé » : Poké Ball dans un petit cercle, en haut à droite -->
        <FrameLayout
            android:id="@+id/badgeCapture"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_circle_btn"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_pokeball"
                app:tint="#FFFFFF" />
        </FrameLayout>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
