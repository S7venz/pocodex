<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detailRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== En-tête type-coloré ===== -->
            <FrameLayout
                android:id="@+id/entete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="190dp"
                    android:layout_height="190dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="-36dp"
                    android:alpha="0.13"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_pokeball"
                    app:tint="#FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="22dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_nav_btn"
                        android:contentDescription="@string/combat_titre"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_back"
                        app:tint="#FFFFFF" />

                    <ImageView
                        android:id="@+id/imgArt"
                        android:layout_width="206dp"
                        android:layout_height="206dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="2dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtNom"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/bungee"
                            android:includeFontPadding="false"
                            android:shadowColor="#38000000"
                            android:shadowDx="0"
                            android:shadowDy="3"
                            android:shadowRadius="0.01"
                            android:textColor="#FFFFFF"
                            android:textSize="28sp" />

                        <TextView
                            android:id="@+id/txtNumero"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginBottom="5dp"
                            android:fontFamily="@font/press_start_2p"
                            android:includeFontPadding="false"
                            android:textColor="#D9FFFFFF"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/chipsTypes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/foil_sheen" />
            </FrameLayout>

            <!-- ===== Corps ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Tuiles Taille / Poids / Nature -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="@font/press_start_2p"
                            android:text="TAILLE"
                            android:textColor="@color/gris5"
                            android:textSize="7sp" />

                        <TextView
                            android:id="@+id/txtTaille"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/baloo2_black"
                            android:textColor="@color/encre2"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="@font/press_start_2p"
                            android:text="POIDS"
                            android:textColor="@color/gris5"
                            android:textSize="7sp" />

                        <TextView
                            android:id="@+id/txtPoids"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/baloo2_black"
                            android:textColor="@color/encre2"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tile"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="@font/press_start_2p"
                            android:text="NATURE"
                            android:textColor="@color/gris5"
                            android:textSize="7sp" />

                        <TextView
                            android:id="@+id/txtNature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/baloo2_black"
                            android:textColor="@color/encre2"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/outfit"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/gris1"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/baloo2_black"
                    android:text="@string/statistiques"
                    android:textColor="@color/encre2"
                    android:textSize="16sp" />

                <LinearLayout
                    android:id="@+id/conteneurStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical" />

                <!-- Actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/btnFavori"
                        android:layout_width="54dp"
                        android:layout_height="52dp"
                        android:background="@drawable/btn_starbox">

                        <ImageView
                            android:id="@+id/imgFavori"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:layout_marginBottom="3dp"
                            android:contentDescription="@string/favoris"
                            android:src="@drawable/ic_star_border"
                            app:tint="@color/or_btn2" />
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/btnCombat"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="9dp"
                        android:layout_marginEnd="9dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_red"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_sword" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/baloo2_black"
                            android:text="Combattre"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnEquipe"
                        android:layout_width="54dp"
                        android:layout_height="52dp"
                        android:background="@drawable/btn_white"
                        android:fontFamily="@font/baloo2_black"
                        android:gravity="center"
                        android:paddingBottom="6dp"
                        android:text="+"
                        android:textColor="#3A3A46"
                        android:textSize="30sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/detailProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/rouge" />
</FrameLayout>
