<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nuit"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Barre rouge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_topbar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="11dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_nav_btn"
            android:contentDescription="@string/combat_titre"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="11dp"
            android:fontFamily="@font/bungee"
            android:shadowColor="@color/rouge_fonce"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="0.01"
            android:text="COMBAT EN LIGNE"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/lobbyContenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- ===== CRÉER ===== -->
            <LinearLayout
                android:id="@+id/btnCreer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_red"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bungee"
                    android:shadowColor="@color/rouge_fonce"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="0.01"
                    android:text="Créer une partie"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/outfit"
                    android:text="Génère un code et partage-le à un ami."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/bg_lcd_code"
                    android:fontFamily="@font/press_start_2p"
                    android:gravity="center"
                    android:letterSpacing="0.25"
                    android:paddingVertical="14dp"
                    android:shadowColor="#807BE08A"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="12"
                    android:textColor="@color/lcd_vert"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="13dp"
                    android:fontFamily="@font/press_start_2p"
                    android:text="APPUIE POUR LANCER"
                    android:textColor="#FFFFFF"
                    android:textSize="7sp" />
            </LinearLayout>

            <!-- ===== OU ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="@color/bord2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:fontFamily="@font/press_start_2p"
                    android:text="OU"
                    android:textColor="@color/gris4"
                    android:textSize="9sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="@color/bord2" />
            </LinearLayout>

            <!-- ===== REJOINDRE ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bungee"
                    android:text="Rejoindre"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/outfit"
                    android:text="Saisis le code reçu de ton ami."
                    android:textColor="@color/gris4"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/editCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/bg_lcd_code"
                    android:fontFamily="@font/press_start_2p"
                    android:gravity="center"
                    android:hint="CODE"
                    android:importantForAutofill="no"
                    android:inputType="textCapCharacters"
                    android:letterSpacing="0.25"
                    android:maxLength="6"
                    android:maxLines="1"
                    android:paddingVertical="14dp"
                    android:textColor="@color/lcd_vert"
                    android:textColorHint="#3F8A3A"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/btnRejoindre"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/btn_blue"
                    android:fontFamily="@font/baloo2_black"
                    android:gravity="center"
                    android:paddingBottom="5dp"
                    android:text="Rejoindre le combat"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/outfit"
                android:gravity="center"
                android:text="Une fois connectés, le combat se joue dans l'arène — même interface, en temps réel."
                android:textColor="@color/gris4"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
