<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ecran"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Barre rouge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_topbar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="11dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_nav_btn"
            android:contentDescription="@string/combat_titre"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="11dp"
            android:layout_weight="1"
            android:fontFamily="@font/bungee"
            android:shadowColor="@color/rouge_fonce"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="0.01"
            android:text="MON ÉQUIPE"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/press_start_2p"
            android:textColor="#FFD9D2"
            android:textSize="9sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/conteneurEquipe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />
    </ScrollView>

    <TextView
        android:id="@+id/btnCombatEquipe"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_margin="14dp"
        android:background="@drawable/btn_red"
        android:drawablePadding="8dp"
        android:fontFamily="@font/bungee"
        android:gravity="center"
        android:paddingBottom="5dp"
        android:shadowColor="@color/rouge_fonce"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="0.01"
        android:text="COMBATTRE"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        app:drawableStartCompat="@drawable/ic_sword" />
</LinearLayout>
