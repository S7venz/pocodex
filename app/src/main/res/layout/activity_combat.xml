<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/combatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nuit"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/combatToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/bg_topbar"
        app:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar"
        app:titleTextColor="#FFFFFF" />

    <!-- ===== Scène ===== -->
    <FrameLayout
        android:id="@+id/arene"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_arena_sky"
        android:clipChildren="false">

        <!-- Plateformes (derrière les sprites) -->
        <View
            android:layout_width="150dp"
            android:layout_height="30dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="150dp"
            android:layout_marginEnd="26dp"
            android:background="@drawable/bg_platform" />

        <View
            android:layout_width="180dp"
            android:layout_height="36dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="42dp"
            android:background="@drawable/bg_platform" />

        <!-- Sprite adversaire -->
        <ImageView
            android:id="@+id/advSprite"
            android:layout_width="146dp"
            android:layout_height="146dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="66dp"
            android:layout_marginEnd="28dp"
            android:contentDescription="@string/combat_titre"
            android:scaleType="fitCenter" />

        <!-- Sprite joueur -->
        <ImageView
            android:id="@+id/joueurSprite"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="56dp"
            android:contentDescription="@string/combat_titre"
            android:scaleType="fitCenter" />

        <!-- Jauge LCD adversaire (haut-gauche) -->
        <LinearLayout
            android:layout_width="206dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="12dp"
            android:background="@drawable/bg_lcd"
            android:orientation="vertical"
            android:paddingStart="11dp"
            android:paddingTop="8dp"
            android:paddingEnd="11dp"
            android:paddingBottom="9dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/advNom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/baloo2_black"
                    android:textColor="@color/lcd_nom"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/advHpTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:textColor="@color/lcd_label"
                    android:textSize="7sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="PV"
                    android:textColor="@color/lcd_pv"
                    android:textSize="7sp" />

                <ProgressBar
                    android:id="@+id/advHpBar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="9dp"
                    android:layout_marginStart="7dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progressDrawable="@drawable/lcd_hp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/advChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- Jauge LCD joueur (bas-droite) -->
        <LinearLayout
            android:layout_width="206dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="12dp"
            android:background="@drawable/bg_lcd"
            android:orientation="vertical"
            android:paddingStart="11dp"
            android:paddingTop="8dp"
            android:paddingEnd="11dp"
            android:paddingBottom="9dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/joueurNom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/baloo2_black"
                    android:textColor="@color/lcd_nom"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/joueurHpTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:textColor="@color/lcd_label"
                    android:textSize="7sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="PV"
                    android:textColor="@color/lcd_pv"
                    android:textSize="7sp" />

                <ProgressBar
                    android:id="@+id/joueurHpBar"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="9dp"
                    android:layout_marginStart="7dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progressDrawable="@drawable/lcd_hp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/joueurChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/combatProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <View
            android:id="@+id/flashEcran"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="@color/fond_blanc"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <!-- ===== Panneau de commande ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_panel"
        android:orientation="vertical"
        android:paddingStart="13dp"
        android:paddingTop="12dp"
        android:paddingEnd="13dp"
        android:paddingBottom="15dp">

        <ScrollView
            android:id="@+id/logScroll"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:background="@drawable/bg_journal"
            android:padding="11dp">

            <TextView
                android:id="@+id/logText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/outfit"
                android:lineSpacingExtra="2dp"
                android:textColor="#CFCFDA"
                android:textSize="12.5sp" />
        </ScrollView>

        <LinearLayout
            android:id="@+id/movesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:orientation="vertical" />
    </LinearLayout>
</LinearLayout>
