<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_accueil"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="40dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <!-- ===================== HÉROS ===================== -->
        <!-- Logo : plaque rouge + orbe Poké Ball + reflet foil -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_logo_heros">

            <ImageView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_gravity="center"
                android:layout_marginBottom="6dp"
                android:contentDescription="@string/accueil_titre"
                android:src="@drawable/ic_pokeball"
                app:tint="#FFFFFF" />

            <!-- Reflet foil sur la plaque -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="6dp"
                android:background="@drawable/foil_logo" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/bungee"
            android:includeFontPadding="false"
            android:letterSpacing="0.02"
            android:shadowColor="@color/rouge_fonce"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="0.01"
            android:text="@string/accueil_titre"
            android:textColor="#FFFFFF"
            android:textSize="40sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:fontFamily="@font/press_start_2p"
            android:letterSpacing="0.12"
            android:text="@string/accueil_sous_titre"
            android:textColor="@color/or"
            android:textSize="9sp" />

        <!-- ===================== FORMULAIRE ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:background="@drawable/bg_carte_formulaire"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- Pseudo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.08"
                android:text="@string/accueil_label_pseudo"
                android:textColor="@color/gris4"
                android:textSize="7sp" />

            <EditText
                android:id="@+id/champPseudo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="9dp"
                android:background="@drawable/bg_champ_sombre"
                android:fontFamily="@font/outfit"
                android:hint="@string/accueil_pseudo_hint"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLength="16"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="@color/gris4"
                android:textSize="15sp" />

            <!-- Mot de passe -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.08"
                android:text="@string/accueil_label_mdp"
                android:textColor="@color/gris4"
                android:textSize="7sp" />

            <EditText
                android:id="@+id/champMdp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="9dp"
                android:background="@drawable/bg_champ_sombre"
                android:fontFamily="@font/outfit"
                android:hint="@string/accueil_mdp_hint"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="@color/gris4"
                android:textSize="15sp" />

            <!-- Connexion -->
            <TextView
                android:id="@+id/btnConnexion"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/btn_red"
                android:fontFamily="@font/bungee"
                android:gravity="center"
                android:paddingBottom="5dp"
                android:shadowColor="@color/rouge_ombre"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="0.01"
                android:text="@string/accueil_connexion"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <!-- Créer un compte -->
            <TextView
                android:id="@+id/btnCreer"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_gold"
                android:fontFamily="@font/baloo2_black"
                android:gravity="center"
                android:paddingBottom="5dp"
                android:text="@string/accueil_creer"
                android:textColor="#5A3D00"
                android:textSize="17sp" />
        </LinearLayout>

        <!-- ===================== HORS-LIGNE ===================== -->
        <TextView
            android:id="@+id/btnHorsLigne"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:fontFamily="@font/baloo2_bold"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/accueil_hors_ligne"
            android:textColor="@color/gris4"
            android:textSize="15sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ===================== SERVEUR (discret) ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:fontFamily="@font/press_start_2p"
                android:text="@string/accueil_label_serveur"
                android:textColor="@color/gris4"
                android:textSize="8sp" />

            <EditText
                android:id="@+id/champServeur"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_champ_sombre"
                android:fontFamily="@font/outfit"
                android:hint="@string/accueil_serveur_hint"
                android:importantForAutofill="no"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/gris5"
                android:textColorHint="@color/bord2"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
